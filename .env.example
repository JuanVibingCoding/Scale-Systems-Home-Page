# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only).
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
NEXT_PUBLIC_APP_URL="https://scalesystems.dev"

# SUPABASE_URL: Your Supabase project URL (required for /api/lead).
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_SECRET_KEY: Your Supabase service_role key (required for /api/lead).
SUPABASE_SECRET_KEY="your-service-role-key"

# RESEND_API_KEY: Required for sending email notifications (lead alerts).
RESEND_API_KEY="re_..."

# RESEND_FROM_EMAIL: The "from" address for transactional emails.
RESEND_FROM_EMAIL="contacto@scalesystems.dev"

# NOTIFY_EMAILS: Comma-separated list of emails to notify on new leads.
NOTIFY_EMAILS="hola@scalesystems.dev"
...