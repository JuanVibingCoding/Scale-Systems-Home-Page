# ─── CLIENTE (expuestas al bundle, prefijo VITE_) ───────────────────
# El cliente NO necesita claves. Solo variables públicas.
VITE_APP_URL="https://scalesystems.com.ve"

# ─── SERVIDOR (Vercel Functions / Edge) — NUNCA en el bundle ────────
# Gemini (chatbot proxy + ai_summary en leads)
GEMINI_API_KEY="tu_clave_de_gemini"

# Supabase
SUPABASE_URL="https://tuproyecto.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_anon_key"
SUPABASE_SECRET_KEY="sb_secret_service_role_key"
SUPABASE_JWKS_URL="https://tuproyecto.supabase.co/auth/v1/.well-known/jwks.json"

# Resend (email transaccional)
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="hola@scalesystems.com.ve"
RESEND_TO_EMAIL="ventas@scalesystems.com.ve"

# App
APP_URL="https://scalesystems.com.ve"

# ─── MCP (solo para OpenCode local, no para Vercel) ─────────────────
# Personal Access Token de Supabase (distinto al service role key)
# Generar en: https://supabase.com/dashboard/account/tokens
SUPABASE_MCP_TOKEN="sbp_xxxxxxxxxxxxxxxxxxxx"
SUPABASE_PROJECT_REF="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
VERCEL_TOKEN="vc_xxxxxxxxxxxxxxxxxxxx"
